  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas-build-pre-install": "chmod -R u+rwX ios 2>/dev/null || true; for f in ios/.xcode.env ios/.xcode.env.local; do [ -f \"$f\" ] && tr -d '\\r' < \"$f\" > \"$f.tmp\" && mv \"$f.tmp\" \"$f\"; done; true"
  },
